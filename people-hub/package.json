{
  "name": "tarabut-people-hub",
  "version": "0.1.0-stage1",
  "private": true,
  "description": "Tarabut People Hub — internal People Portal. Stage 1: foundation.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "eslint-config-next": "^15.5.20",
    "next": "^15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "prisma": "5.22.0",
    "tsx": "4.19.1",
    "typescript": "5.5.4"
  }
}
